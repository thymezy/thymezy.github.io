{
  "layout": {
    "type": "split",
    "direction": "horizontal",
    "areas": [
      { "name": "leftPane", "width": "560px" },
      { "name": "mainPane", "flex": 1 }
    ]
  },

  "components": [
    /* ---------- LEFT‑PANE (two dynamic columns) ---------- */
    {
      "id": "leftPaneLayout",
      "area": "leftPane",
      "type": "layout",
      "layout": {
        "type": "split",
        "direction": "horizontal",
        "areas": [
          { "name": "authorsCol", "width": "280px" },
          { "name": "assetsCol",  "width": "280px" }
        ]
      }
    },

    /* Authors column */
    {
      "id": "authorList",
      "area": "authorsCol",
      "type": "list",
      "header": "Authors",
      "selection": { "mode": "multiple", "bind": "selectedAuthors" },
      "item": {
        "type": "card",
        "fields": [
          { "model": "name",       "role": "title" },
          { "model": "language",   "options": ["chinese", "english"] },
          { "model": "style",      "options": ["technical_analysis"] },
          { "model": "ref_type",   "options": ["youtube", "medium"] },
          { "model": "frequency" },
          { "model": "format" },
          { "model": "autoPublish" }
        ],
        "actions": [
          {
            "icon": "settings",
            "action": "openConfigDialog",
            "payload": {
              "fields": [
                {
                  "model": "long_term",
                  "type": "slider",
                  "range": { "min": 1, "max": 365 },
                  "unitField": "long_term_unit",
                  "unitOptions": ["day", "week", "month", "quarter", "year"]
                },
                {
                  "model": "mid_term",
                  "type": "slider",
                  "range": { "min": 1, "max": 365 },
                  "unitField": "mid_term_unit",
                  "unitOptions": ["day", "week", "month", "quarter", "year"]
                },
                {
                  "model": "short_term",
                  "type": "slider",
                  "range": { "min": 1, "max": 365 },
                  "unitField": "short_term_unit",
                  "unitOptions": ["day", "week", "month", "quarter", "year"]
                },
                {
                  "model": "ultra_short_term",
                  "type": "slider",
                  "range": { "min": 1, "max": 365 },
                  "unitField": "ultra_short_term_unit",
                  "unitOptions": ["day", "week", "month", "quarter", "year"]
                }
              ]
            }
          }
        ]
      },
      "dataSource": "authors"
    },

    /* Assets column */
    {
      "id": "assetList",
      "area": "assetsCol",
      "type": "list",
      "header": "Assets",
      "selection": { "mode": "multiple", "bind": "selectedAssets" },
      "item": {
        "type": "card",
        "style": "compact",
        "model": "assetName"
      },
      "dataSource": {
        "expression": "{{authors | filter(a => selectedAuthors.includes(a.id)) | flatMap('assets')}}"
      }
    },

    /* Process button */
    {
      "id": "processBtn",
      "area": "leftPane",
      "type": "button",
      "position": "bottom",
      "text": "Process Selected ({{selectedAuthors.length}})",
      "disabled": "{{selectedAuthors.length === 0}}",
      "action": "processSelection"
    },

    /* ---------- MAIN‑PANE ---------- */
    {
      "id": "mainPaneLayout",
      "area": "mainPane",
      "type": "layout",
      "layout": { "type": "stack", "direction": "vertical" }
    },

    /* Analysis‑type multi‑select */
    {
      "id": "analysisTypeSelector",
      "area": "mainPane",
      "type": "multiSelect",
      "header": "Show Analysis Types",
      "selection": { "bind": "selectedAnalysisTypes" },
      "options": [
        "key_levels",
        "indicators",
        "volume_analysis",
        "market_sentiment",
        "risk_warnings",
        "correlation_analysis",
        "strategy_suggestions"
      ]
    },

    /* Content display panel */
    {
      "id": "contentPanel",
      "area": "mainPane",
      "type": "panel",
      "header": "Content Display",
      "emptyState": {
        "type": "text",
        "value": "Select authors from the left panel to view their content",
        "visible": "{{selectedAuthors.length === 0}}"
      },
      "body": {
        "type": "dynamicContent",
        "dataSource": "authorContent",
        "visible": "{{selectedAuthors.length > 0}}",
        "filter": {
          "analysisTypes": "{{selectedAnalysisTypes}}",
          "assets": "{{selectedAssets}}"
        }
      }
    }
  ],

  "dataSources": {
    "authors":        { "endpoint": "/api/authors" },
    "authorContent":  {
      "endpoint": "/api/authors/content",
      "params": {
        "authorIds": "{{selectedAuthors}}",
        "assets":    "{{selectedAssets}}",
        "analysisTypes": "{{selectedAnalysisTypes}}"
      }
    }
  }
}
